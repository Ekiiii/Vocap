{
  "name": "vocap",
  "private": true,
  "version": "0.2.8",
  "description": "Logiciel de Bande Rythmo pour tous les fandubers",
  "author": "Ekiii",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "build:web": "cmd /C \"vite build -c vite.web.config.ts\"",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint .",
    "electron": "cmd /C \"set ELECTRON_RUN_AS_NODE=&& node_modules\\.bin\\electron.cmd .\"",
    "dist": "node node_modules/electron-vite/bin/electron-vite.js build && node node_modules/electron-builder/cli.js"
  },
  "build": {
    "appId": "com.vocap.app",
    "productName": "VOCAP",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "src/assets/vocap_logo.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://download.vocap.fr/"
      }
    ],
    "files": [
      "out/**/*",
      "src/assets/**/*",
      "src/main/**/*.py",
      "package.json",
      "!node_modules/onnxruntime-node/bin/napi-v6/darwin",
      "!node_modules/onnxruntime-node/bin/napi-v6/linux"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*",
      "**/node_modules/onnxruntime-node/**/*",
      "src/main/**/*.py"
    ]
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "ffmpeg-static": "^5.3.0",
    "onnxruntime-node": "^1.24.1"
  },
  "devDependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@xenova/transformers": "^2.17.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.564.0",
    "tailwind-merge": "^3.4.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "electron": "^33.2.0",
    "electron-builder": "^26.7.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}